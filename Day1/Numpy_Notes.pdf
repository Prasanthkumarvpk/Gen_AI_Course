from numpy import random

# poisson(lam=average_events, size)
# lam = average events per interval
data = random.poisson(lam=5, size=20)
print("Poisson (avg 5 events):", data)

# Real example: customer calls per hour
# Call center gets avg 10 calls/hour
calls = random.poisson(lam=10, size=24)   # 24 hours
print(f"\nCalls per hour (24hrs): {calls}")
print(f"Total calls today: {calls.sum()}")
print(f"Busiest hour    : {calls.max()} calls")


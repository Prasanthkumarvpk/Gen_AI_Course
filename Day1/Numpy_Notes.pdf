# ============================================================
# 36. MATHEMATICAL OPERATIONS
# ============================================================

print("\n" + "=" * 60)
print("36. MATHEMATICAL OPERATIONS")
print("=" * 60)

arr = np.array([1, 2, 3, 4, 5])

# Basic operations
print("arr        :", arr)
print("sum        :", np.sum(arr))        # 15
print("mean       :", np.mean(arr))       # 3.0
print("max        :", np.max(arr))        # 5
print("min        :", np.min(arr))        # 1
print("std dev    :", np.std(arr))        # 1.41
print("variance   :", np.var(arr))        # 2.0
print("median     :", np.median(arr))     # 3.0

# Math functions
arr = np.array([1, 4, 9, 16, 25])
print("\nsqrt   :", np.sqrt(arr))         # [1. 2. 3. 4. 5.]
print("abs    :", np.abs([-1,-2,3,-4]))  # [1 2 3 4]
print("power  :", np.power(arr, 2))      # [1 16 81 256 625]
print("log    :", np.log(arr).round(2))  # natural log
print("log10  :", np.log10(arr))         # base 10
print("exp    :", np.exp([1, 2, 3]).round(2))  # e^x

# Arithmetic between arrays
a = np.array([10, 20, 30])
b = np.array([1, 2, 3])
print("\na + b :", a + b)    # [11 22 33]
print("a - b :", a - b)    # [9 18 27]
print("a * b :", a * b)    # [10 40 90]
print("a / b :", a / b)    # [10. 10. 10.]
print("a % b :", a % b)    # [0 0 0]

# 2D sum along axis
arr = np.array([[1, 2, 3],
                [4, 5, 6]])
print("\n2D sum (all)    :", np.sum(arr))         # 21
print("2D sum (axis=0):", np.sum(arr, axis=0))   # [5 7 9] (col sum)
print("2D sum (axis=1):", np.sum(arr, axis=1))   # [6 15]  (row sum)

# ============================================================
# 37. MATRIX OPERATIONS - DOT()
# ============================================================

print("\n" + "=" * 60)
print("37. MATRIX OPERATIONS - DOT()")
print("=" * 60)

# dot() = Matrix multiplication
a = np.array([[1, 2],
              [3, 4]])
b = np.array([[5, 6],
              [7, 8]])

print("Matrix A:\n", a)
print("Matrix B:\n", b)

result = np.dot(a, b)
print("A dot B:\n", result)
# [[1*5+2*7  1*6+2*8]   =   [[19 22]
#  [3*5+4*7  3*6+4*8]]       [43 50]]

# matmul - same as dot for 2D
result2 = np.matmul(a, b)
print("matmul:\n", result2)    # same result

# transpose
print("\nTranspose of A:\n", a.T)
# [[1 3]
#  [2 4]]

# determinant
det = np.linalg.det(a)
print("\nDeterminant of A:", det)   # -2.0

# inverse
inv = np.linalg.inv(a)
print("Inverse of A:\n", inv)

# Real use: Linear algebra in ML
# w = (X^T X)^-1 X^T y  (Linear Regression formula)

# ============================================================
# 38. BROADCASTING
# ============================================================

print("\n" + "=" * 60)
print("38. BROADCASTING")
print("=" * 60)

# Broadcasting = operations on arrays with different shapes

# Scalar + Array
arr = np.array([1, 2, 3, 4, 5])
print("arr + 10  :", arr + 10)    # [11 12 13 14 15]
print("arr * 2   :", arr * 2)     # [2 4 6 8 10]
print("arr ** 2  :", arr ** 2)    # [1 4 9 16 25]

# 2D + 1D broadcasting
a = np.array([[1, 2, 3],
              [4, 5, 6]])
b = np.array([10, 20, 30])

result = a + b
print("\n2D + 1D broadcasting:\n", result)
# [[11 22 33]
#  [14 25 36]]

# Real use: normalize data
data = np.array([[100, 200, 300],
                 [400, 500, 600]])
col_mean = data.mean(axis=0)
normalized = data - col_mean
print("\nNormalized:\n", normalized)

